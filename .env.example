# Copy this to .env.local

# Google Cloud Text-to-Speech API (Required for TTS)
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here

# Anthropic API (Required for Insights mode)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GitHub Token (Optional - for "Save to Ecosystem" feature)
# Create a token with repo scope from: https://github.com/settings/tokens
GITHUB_HELIX_MIND_TOKEN=your-github-personal-access-token

# Copy this to .env.local and add your Google Cloud API key
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here

# Optional: Customize default voice settings
# Recommended voices (FREE tier - 4M chars/month):

# 🇺🇸 US Voices (Standard)
# en-US-Standard-A (Female), en-US-Standard-B (Male)
# en-US-Standard-C (Female), en-US-Standard-D (Male)
# en-US-Standard-E (Female), en-US-Standard-F (Female)

# 🇺🇸 US Voices (WaveNet - Better Quality, still in free tier)
# en-US-Wavenet-A (Female), en-US-Wavenet-B (Male)
# en-US-Wavenet-C (Female), en-US-Wavenet-D (Male)
# en-US-Wavenet-E (Female), en-US-Wavenet-F (Female)

# 🇬🇧 UK Voices (Standard)
# en-GB-Standard-A (Female), en-GB-Standard-B (Male)
# en-GB-Standard-C (Female), en-GB-Standard-D (Male)

# 🇬🇧 UK Voices (WaveNet - Better Quality)
# en-GB-Wavenet-A (Female), en-GB-Wavenet-B (Male)
# en-GB-Wavenet-C (Female), en-GB-Wavenet-D (Male)
# en-GB-Wavenet-F (Female)

# 🇦🇺 Australian Voices (Standard)
# en-AU-Standard-A (Female), en-AU-Standard-B (Male)
# en-AU-Standard-C (Female), en-AU-Standard-D (Male)

# 🇦🇺 Australian Voices (WaveNet - Better Quality)
# en-AU-Wavenet-A (Female), en-AU-Wavenet-B (Male)
# en-AU-Wavenet-C (Female), en-AU-Wavenet-D (Male)

# Default voice (used if none specified)
DEFAULT_VOICE=en-GB-Wavenet-A

# Speaking rate: 0.25 to 4.0 (1.0 = normal speed)
DEFAULT_SPEED=1.0
